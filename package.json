{
  "name": "adgen",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "npm run db:migrate && npm run build && (cp .dev.vars .output/.dev.vars 2>/dev/null || true) && npx wrangler dev",
    "preview": "npx wrangler dev",
    "deploy": "npm run build && npx wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:migrate:remote": "node scripts/db-migrate.mjs --remote",
    "db:migrate:both": "node scripts/db-migrate.mjs && node scripts/db-migrate.mjs --remote",
    "db:studio": "bash scripts/db-studio.sh",
    "postinstall": "node -e \"const fs=require('fs'),p='node_modules/@cloudflare/unenv-preset/package.json',j=JSON.parse(fs.readFileSync(p,'utf8'));if(j.sideEffects===false){delete j.sideEffects;fs.writeFileSync(p,JSON.stringify(j,null,2)+'\\n');console.log('[postinstall] Patched @cloudflare/unenv-preset: removed sideEffects:false (Wrangler 4.81.1 workaround)')}\""
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "marked": "^18.0.0",
    "nuxt": "^4.4.2",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.6.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.81.1"
  }
}
